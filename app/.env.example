VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Database password (Settings → Database) — used by CLI migrations, not the Vite app
SUPABASE_DATABASE_PASSWORD=your-database-password

# --- Mux (browser-safe; Settings → General in the Mux dashboard) ---
# Environment ID and Environment Key — used by Mux Player / Mux Data (viewer metrics).
# Do not put Mux API tokens here; those belong only on your server (see below).
VITE_MUX_ENVIRONMENT_ID=your-mux-environment-id
VITE_MUX_ENV_KEY=your-mux-environment-key
# Optional: single test asset while wiring the player before your API returns playback IDs
# VITE_MUX_PLAYBACK_ID=your-playback-id
# App calls your Edge Function (create e.g. supabase/functions/mux — same pattern as feedback)
VITE_MUX_FUNCTION_URL=https://your-project-ref.supabase.co/functions/v1/mux

# --- Mux API & signing (server-only — never use the VITE_ prefix) ---
# Create the access token under Mux → Settings → Access Tokens (Video permissions).
# This file is your inventory: same variable names should exist wherever the backend runs.
# Supabase Edge Functions: Project Settings → Edge Functions → Secrets, or:
#   supabase secrets set MUX_TOKEN_ID="..." MUX_TOKEN_SECRET="..."
# If you switch hosts later, map these names in the new platform’s secret store.
MUX_TOKEN_ID=your-mux-access-token-id
MUX_TOKEN_SECRET=your-mux-access-token-secret
# Optional signed playback (Mux → Settings → Signing Keys). PEM is easier to paste in the
# Supabase Dashboard (multiline secret) than in a single-line .env file.
MUX_SIGNING_KEY_ID=your-mux-signing-key-id
MUX_SIGNING_KEY_PRIVATE_KEY=your-mux-signing-key-private-key-pem-or-leave-empty

VITE_TEAMS_TENANT_ID=your-teams-tenant-id
VITE_TEAMS_CLIENT_ID=your-teams-client-id
VITE_FEEDBACK_FUNCTION_URL=https://your-project-ref.supabase.co/functions/v1/create-linear-ticket
LINEAR_PROJECT_ID=
LINEAR_TEAM_ID=
LINEAR_API_KEY=

# --- Cloudflare Pages / CI (Wrangler — not read by the Vite app at runtime) ---
# Create an API token: Cloudflare dashboard → My Profile → API Tokens → Create Token.
# Use a custom token with “Cloudflare Pages — Edit” (and “Account — Account Settings — Read” if prompted).
# Set these in your CI / deploy environment and optionally copy to a local .env only for manual deploys.
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# Optional; Wrangler will infer from the token when possible. Set if deploy logs ask for it.
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
# Optional: pin the Node version in Pages (Builds → Environment variables) or add app/.nvmrc
# NODE_VERSION=22

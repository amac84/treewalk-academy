# Copy to `.env` locally. Do not commit `.env` or paste real secrets into tracked files.
# See README.md for what is safe to expose in the client vs server-only.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Video mux Edge Function needs a Supabase user JWT. Seeded/demo roles do not run Supabase Auth sign-in.
# Default: production allows anonymous JWT bootstrap unless you set this to false (strict, real-auth-only).
# Requires Anonymous provider enabled in Supabase (Authentication → Providers) for demo/invite pilots.
# VITE_SUPABASE_MUX_ANON_FALLBACK=false
# When set, full course documents (including hosted video fields) load/save to table academy_courses
# (see supabase/migrations/*_academy_courses.sql). Deploy migration before sharing the pilot build.
# Database password (Settings → Database) — used by CLI migrations, not the Vite app
SUPABASE_DATABASE_PASSWORD=your-database-password

# --- Video player metrics (browser-safe; from your streaming provider’s dashboard) ---
# Environment ID and Environment Key — used by the embedded player for viewer analytics.
# Do not put API signing tokens here; those belong only on your server (see below).
VITE_MUX_ENVIRONMENT_ID=your-mux-environment-id
VITE_MUX_ENV_KEY=your-mux-environment-key
# Optional: single test asset while wiring the player before your API returns playback IDs
# VITE_MUX_PLAYBACK_ID=your-playback-id
# Optional override for the mux Edge Function. If omitted, the app uses VITE_SUPABASE_URL + /functions/v1/mux.
# VITE_MUX_FUNCTION_URL=https://your-project-ref.supabase.co/functions/v1/mux
# Optional: public model selector for transcription requests sent to that Edge Function.
# If omitted, the function defaults to gpt-4o-mini-transcribe.
# VITE_OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# --- Video provider API & signing (server-only — never use the VITE_ prefix) ---
# Create the access token in your video host’s dashboard (video upload permissions).
# This file is your inventory: same variable names should exist wherever the backend runs.
# Supabase Edge Functions: Project Settings → Edge Functions → Secrets, or:
#   supabase secrets set MUX_TOKEN_ID="..." MUX_TOKEN_SECRET="..."
# If you switch hosts later, map these names in the new platform’s secret store.
MUX_TOKEN_ID=your-mux-access-token-id
MUX_TOKEN_SECRET=your-mux-access-token-secret
# OpenAI API key used by the video Edge Function to generate transcripts for uploaded videos.
OPENAI_API_KEY=your-openai-api-key
# Optional server-side model override for metadata drafting (title/summary/description/topic/category).
# OPENAI_COURSE_METADATA_MODEL=gpt-4o-mini
# Optional server-side model override for quiz-bank generation.
# OPENAI_COURSE_QUIZ_MODEL=gpt-4o
# Optional server-side fallback model when primary model hits token/context limits.
# Default is whisper-1 if unset.
# OPENAI_TRANSCRIBE_FALLBACK_MODEL=whisper-1
# Edge Function only: set to true for local dev while the SPA has no Supabase Auth session.
# Omit or set false in production (require Authorization: Bearer <user JWT>).
MUX_ALLOW_UNAUTHENTICATED=false
# Optional signed playback (signing keys from your video host). PEM is easier to paste in the
# Supabase Dashboard (multiline secret) than in a single-line .env file.
MUX_SIGNING_KEY_ID=your-mux-signing-key-id
MUX_SIGNING_KEY_PRIVATE_KEY=your-mux-signing-key-private-key-pem-or-leave-empty

VITE_TEAMS_TENANT_ID=your-teams-tenant-id
VITE_TEAMS_CLIENT_ID=your-teams-client-id
# Browser fetch() to Edge Functions must send the anon/publishable key (see feedback.ts: apikey + Authorization).
VITE_FEEDBACK_FUNCTION_URL=https://your-project-ref.supabase.co/functions/v1/create-linear-ticket
LINEAR_PROJECT_ID=
LINEAR_TEAM_ID=
LINEAR_API_KEY=

# --- Cloudflare Pages / CI (Wrangler — not read by the Vite app at runtime) ---
# Create an API token: Cloudflare dashboard → My Profile → API Tokens → Create Token.
# Use a custom token with “Cloudflare Pages — Edit” (and “Account — Account Settings — Read” if prompted).
# Set these in your CI / deploy environment and optionally copy to a local .env only for manual deploys.
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# Optional; Wrangler will infer from the token when possible. Set if deploy logs ask for it.
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
# Optional: pin the Node version in Pages (Builds → Environment variables) or add app/.nvmrc
# NODE_VERSION=22

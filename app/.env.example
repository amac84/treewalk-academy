# =============================================================================
# Treewalk Academy — `app/.env` (local only; do not commit)
# =============================================================================
#
# Browser-facing values can be set either here as `VITE_*` (preferred for local
# dev) or in `app/public/app-settings.json`. At runtime, `loadAppSettings()` loads
# the JSON, then applies any non-empty `VITE_*` from this file on top (Vite
# inlines them at dev/build time).
#
# Server-only secrets (Mux token, DB password, OpenAI, Linear, Cloudflare,
# Clerk *secret* key, …) belong here only — never in `app-settings.json` if you
# treat that file as world-readable.
#
# =============================================================================
# Browser / SPA (`VITE_*` — inlined into the client bundle)
# =============================================================================

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Cloudflare Pages production: add the same two variables under Project Settings → Environment variables
# (Production + Preview if needed), then redeploy — Vite inlines them at build time.

VITE_MUX_ENVIRONMENT_ID=your-mux-environment-id
VITE_MUX_ENV_KEY=your-mux-environment-key
# VITE_MUX_PLAYBACK_ID=

VITE_MUX_FUNCTION_URL=https://your-project-ref.supabase.co/functions/v1/mux
VITE_FEEDBACK_FUNCTION_URL=https://your-project-ref.supabase.co/functions/v1/create-linear-ticket

# Either is enough; both may be set. Matches `clerkPublishableKey` / `nextPublicClerkPublishableKey` in app-settings.
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Production host: https://academy.treewalk.com — in Clerk (production instance), add Allowed redirect URLs
# `https://academy.treewalk.com/**`, set Application paths Home URL to `/home`, and use the production
# publishable key in Cloudflare Pages env (or app-settings.json for that deploy). Local dev stays on
# http://localhost:5173 with the same path-based sign-in/up routes.

# VITE_OPENAI_TRANSCRIBE_MODEL=

# Optional: comma-separated. Those sign-ins get super_admin in the SPA (also set `superAdminEmails` in app-settings.json).
# VITE_SUPER_ADMIN_EMAILS=you@treewalk.com,other@treewalk.com

# Optional: legal entity named on CPD certificates and transcript. Overrides `cpdProviderName` in `public/app-settings.json`.
# Default when omitted everywhere: Treewalk Consulting Inc.
# VITE_CPD_PROVIDER_NAME=Treewalk Consulting Inc.

# =============================================================================
# Server / CLI / Edge (never exposed as VITE_)
# =============================================================================

SUPABASE_DATABASE_PASSWORD=your-database-password

MUX_TOKEN_ID=your-mux-access-token-id
MUX_TOKEN_SECRET=your-mux-access-token-secret
OPENAI_API_KEY=your-openai-api-key
MUX_ALLOW_UNAUTHENTICATED=false
MUX_SIGNING_KEY_ID=your-mux-signing-key-id
MUX_SIGNING_KEY_PRIVATE_KEY=your-mux-signing-key-private-key-pem-or-leave-empty

# Optional model overrides for Edge Function (see supabase/functions/mux)
# OPENAI_COURSE_METADATA_MODEL=gpt-4o-mini
# OPENAI_COURSE_QUIZ_MODEL=gpt-4o
# OPENAI_TRANSCRIBE_FALLBACK_MODEL=whisper-1

CLERK_SECRET_KEY=sk_test_...
# Supabase Edge → mux function: set the same CLERK_SECRET_KEY as a function secret so draft delete can remove Mux assets.
# Supabase Edge → invite-user function: set the same CLERK_SECRET_KEY so admin invites can trigger Clerk invitation emails.
# If the app shows you as super admin only via superAdminEmails / VITE_SUPER_ADMIN_EMAILS (not Clerk publicMetadata), you MUST also set
# Supabase secret ACADEMY_SUPER_ADMIN_EMAILS on the mux/invite-user functions to the same comma-separated lowercase list, or role checks return 403.

LINEAR_PROJECT_ID=
LINEAR_TEAM_ID=
LINEAR_API_KEY=

CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
# NODE_VERSION=22

# Dependencies & build output (root and nested)
node_modules/
dist/
*.local

# Secrets — never commit real credentials (tracked templates use *.example only)
.env
.env.local
.env.*.local

# Local runtime config (use app/public/app-settings.example.json + Cloudflare `VITE_*` overrides)
app/public/app-settings.json

# Test coverage output
coverage/
app/coverage/

# Keys and tokens
*.pem
.id_rsa
*.p12

# OS / editor
.DS_Store
Thumbs.db

# Cursor — project rules are machine/local; not shared via this repo
.cursor/rules/

# Logs
*.log
npm-debug.log*
